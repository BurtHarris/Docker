# Copy this file to .env and fill in real values before starting the stack.
# Never commit .env to version control — it may contain secrets.
#
# Windows 11 alternative — store the three (*) password / key fields in
# Windows Credential Manager instead of this file:
#   .\setup-secrets.ps1   # store secrets once
#   .\start.ps1           # load secrets and start the stack
# The non-sensitive fields below are still read from .env in both workflows.
#
# Generate strong passwords with:
#   openssl rand -base64 24
#
# Generate hex keys with:
#   openssl rand -hex 32    (for MW_SECRET_KEY)
#   openssl rand -hex 8     (for MW_UPGRADE_KEY)

# ---- Wiki identity ----------------------------------------------------------
# Used as a prefix for container names and Docker volume names.
WIKI_NAME=mywiki

# ---- Database credentials ---------------------------------------------------
DB_NAME=my_wiki
DB_USER=wikiuser
DB_PASSWORD=change_me_use_openssl_rand   # (*) SECRET — use Credential Manager on Windows

# ---- MediaWiki secrets ------------------------------------------------------
# MW_SECRET_KEY must be a long random hex string; never reuse across wikis.
MW_SECRET_KEY=change_me_use_openssl_rand_hex_32   # (*) SECRET — use Credential Manager on Windows
MW_UPGRADE_KEY=change_me_hex_8                    # (*) SECRET — use Credential Manager on Windows

# ---- Site URL ---------------------------------------------------------------
# Must match the URL your users actually visit (including scheme + port).
# Development example:  http://localhost:8080
# Production example:   https://wiki.example.com
MW_SITE_SERVER=http://localhost:8080

# ---- Development port -------------------------------------------------------
# Only used by docker-compose.override.yml (local dev).
DEV_PORT=8080
